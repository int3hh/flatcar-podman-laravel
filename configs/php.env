# PHP / runtime tuning (from compose x-php-environment).
# php.service uses AUTORUN_ENABLED=true; workers override it to false in their unit.
PUID=1000
PGID=1000
AUTORUN_ENABLED=true
AUTORUN_LARAVEL_MIGRATION=true
AUTORUN_LARAVEL_MIGRATION_FORCE=true
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_MEMORY_CONSUMPTION=256
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=16
PHP_OPCACHE_MAX_ACCELERATED_FILES=10000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=0
PHP_POST_MAX_SIZE=120M
PHP_UPLOAD_MAX_FILE_SIZE=120M
PHP_MAX_FILE_UPLOADS=100
